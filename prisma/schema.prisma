datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

enum Role {
  SUPERADMIN
  ADMIN
  FACULTY
  STUDENT
}

enum Permission {
  CREATE_COURSE
  EDIT_COURSE
  DELETE_COURSE
  REGISTER_STUDENT
  REMOVE_STUDENT
  CREATE_FEES
  EDIT_FEES
  DELETE_FEES
  MANAGE_GRADES
  VIEW_REPORTS
  CREATE_ADMIN
  EDIT_ADMIN
  DELETE_ADMIN
  MANAGE_ADMISSIONS
  VIEW_ADMISSION_DASHBOARD
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  staffId       String?   @unique  // For faculty/admin staff identification
  matricNo      String?   @unique  // For student matric number
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STUDENT)
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  
  // Permissions can be simple string array or structured relation
  permissions   String[]  @default([]) // e.g. ["users:read", "users:write"]

  accounts      Account[]
  sessions      Session[]
  
  courses       Course[]  @relation("Enrollments")
  
  notifications Notification[]
  payments      Payment[]
  grades        Grade[]

  // Faculty specific relation (courses taught)
  coursesTaught Course[] @relation("FacultyCourses")
  
  // Admin permissions (Structured)
  assignedPermissions   AdminPermission[]
  
  // Superadmin created admins
  createdAdmins User[] @relation("SuperadminAdmins")
  createdBy     User? @relation("SuperadminAdmins", fields: [createdById], references: [id])
  createdById   String?
  
  // Approval workflows
  approvalsCreated    ApprovalRequest[] @relation("CreatedBy")
  approvalsApproved   ApprovalRequest[] @relation("ApprovedBy")
  
  // Audit Logs
  auditLogs     AuditLog[] @relation("Performer")
  targetLogs    AuditLog[] @relation("Target")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // e.g. "CREATE_ADMIN", "UPDATE_PERMISSION"
  entity      String   // e.g. "User", "Course"
  entityId    String?
  details     Json?    // details about the change

  performerId String
  performer   User     @relation("Performer", fields: [performerId], references: [id])
  
  targetUserId String?
  targetUser   User?    @relation("Target", fields: [targetUserId], references: [id])

  createdAt   DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  department String?
  level     String?  // e.g. "100", "200"
  price     Float    @default(0.0) // Course-specific fee if applicable
  credits   Int      @default(3)   // Course credit units
  
  facultyId String
  faculty   User     @relation("FacultyCourses", fields: [facultyId], references: [id])
  
  students  User[]   @relation("Enrollments")
  grades    Grade[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DepartmentFee {
  id         String   @id @default(cuid())
  department String   @unique
  amount     Float
  updatedAt  DateTime @updatedAt
}

model Grade {
  id        String  @id @default(cuid())
  studentId String
  student   User    @relation(fields: [studentId], references: [id])
  courseId  String
  course    Course  @relation(fields: [courseId], references: [id])
  grade     String
}

model Payment {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation(fields: [studentId], references: [id])
  amount        Float
  currency      String   @default("NGN")
  status        String   // "PENDING", "COMPLETED", "FAILED"
  provider      String   // "flutterwave", "paystack"
  transactionId String?  @unique // ID from the provider
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AdminPermission {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  permission Permission
  grantedAt DateTime @default(now())
  grantedBy String   // Superadmin ID who granted this
  
  @@unique([adminId, permission])
}

model ApprovalRequest {
  id            String   @id @default(cuid())
  type          String   // "COURSE_CREATE", "STUDENT_REGISTER", "FEES_CREATE", etc.
  status        ApprovalStatus @default(PENDING)
  
  createdById   String
  createdBy     User     @relation("CreatedBy", fields: [createdById], references: [id])
  
  approvedById  String?
  approvedBy    User?    @relation("ApprovedBy", fields: [approvedById], references: [id])
  
  data          String   @db.Text // JSON data for the request
  rejectionReason String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Faculty {
  id        String   @id @default(cuid())
  name      String   @unique
  acronym   String   @unique
  departments Department[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        String   @id @default(cuid())
  name      String
  acronym   String
  facultyId String
  faculty   Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([facultyId, acronym])
}

model Admission {
  id        String   @id @default(cuid())
  trackingId String  @unique // Unique ID for applicant to track
  firstName String
  lastName  String
  email     String
  phone     String
  dateOfBirth DateTime
  gender    String
  address   String
  state     String
  country   String

  previousSchool String
  previousGrade  String
  transcriptUrl  String? // Base64 string or URL
  
  program   String // e.g. "Computer Science"
  
  emergencyContactName String
  emergencyContactPhone String
  emergencyContactRelation String
  
  status    ApprovalStatus @default(PENDING)
  submittedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
